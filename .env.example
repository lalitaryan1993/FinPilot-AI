APP_NAME="FinPilot AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────
# Option A: SQLite (zero-config local dev)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite   # defaults to database/database.sqlite

# Option B: MySQL (Docker / production)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=finpilot
# DB_USERNAME=finpilot
# DB_PASSWORD=secret

# ─── Session / Cache / Queue ─────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

# Use redis for Docker / production:
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis

# ─── Redis (Docker / production only) ───────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── AI Providers ────────────────────────────────────────────────
# Add at least one. Users can also set their own keys in the app
# under Settings → AI Configuration.

# Anthropic Claude (recommended — best for PDF parsing + Smart Import)
ANTHROPIC_API_KEY=

# OpenAI GPT-4o
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# ─── Filesystem ──────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Mail (optional) ─────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@finpilot.app"
MAIL_FROM_NAME="${APP_NAME}"

# ─── AWS S3 (optional — for file storage in production) ──────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Vite ────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
